{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "Review",
    "description": "Product reviews submitted by customers"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "rating": {
      "type": "integer",
      "required": true,
      "min": 1,
      "max": 5
    },
    "comment": {
      "type": "text",
      "required": true
    },
    "author_name": {
      "type": "string",
      "required": true
    },
    "author_email": {
      "type": "email",
      "required": true
    },
    "product_strapi_id": {
      "type": "integer",
      "required": true
    },
    "product_slug": {
      "type": "string",
      "required": true
    },
    "is_verified_purchase": {
      "type": "boolean",
      "default": false
    },
    "is_approved": {
      "type": "boolean",
      "default": false
    }
  }
}
